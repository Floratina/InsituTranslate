{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InsituTranslate",
  "version": "0.1.0",
  "identifier": "com.insitutranslate.desktop",
  "build": {
    "beforeDevCommand": "pnpm.cmd dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm.cmd build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "InsituTranslate",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 620,
        "resizable": true,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
